{
  "tasks": {
    "postprocess": "deno run -A postprocess.ts",
    "backfill": "deno run --allow-run=git --allow-read --allow-write scripts/backfill.ts",
    "derive": "TZ=UTC deno run --allow-read --allow-write scripts/derive.ts",
    "health": "deno run --allow-read --allow-write --allow-run=git,gh scripts/health.ts",
    "test": "deno task test:pure && TZ=UTC deno test --allow-read src/",
    "test:pure": "deno test --no-prompt src/parser_test.ts src/csv_test.ts src/clock_test.ts src/backfill_test.ts src/derive_test.ts src/health_test.ts src/current_json_test.ts",
    "bless": "deno run --allow-read --allow-write src/bless.ts",
    "check": "deno check src/ scripts/backfill.ts scripts/derive.ts scripts/health.ts postprocess.ts"
  },
  "imports": {
    "deno-dom": "jsr:@b-fuze/deno-dom@0.1.49",
    "@std/assert": "jsr:@std/assert@1",
    "@std/csv": "jsr:@std/csv@1",
    "chroma-js": "npm:chroma-js@3",
    "luxon": "npm:luxon@3"
  },
  "fmt": {
    "lineWidth": 100,
    "include": ["src/", "scripts/backfill.ts", "scripts/derive.ts", "scripts/health.ts"],
    "exclude": ["src/fixtures/", "src/testdata/"]
  },
  "lint": {
    "include": ["src/", "scripts/backfill.ts", "scripts/derive.ts", "scripts/health.ts"]
  }
}
